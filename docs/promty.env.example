# Promty memory generation
#
# Copy the values you need into .env.local or backend/.env.local.
# Do not commit real API keys.

# Required to enable OpenAI-backed Memory Draft and Project Memory generation.
PROMTY_OPENAI_API_KEY=

# Optional. Defaults are shown here.
PROMTY_OPENAI_MODEL=gpt-5-mini
PROMTY_OPENAI_TIMEOUT_SECONDS=90
PROMTY_OPENAI_REASONING_EFFORT=minimal
PROMTY_MEMORY_GENERATOR=openai
PROMTY_MEMORY_CHUNK_GENERATOR=local
PROMTY_MEMORY_DRAFT_GENERATOR=openai
PROMTY_PROJECT_MEMORY_GENERATOR=openai

# Optional Gemini fallback.
PROMTY_GEMINI_API_KEY=
PROMTY_GEMINI_MODEL=gemini-2.5-flash
PROMTY_GEMINI_TIMEOUT_SECONDS=30

# Set this to force deterministic local summaries even when provider keys exist.
# PROMTY_MEMORY_GENERATOR=local
