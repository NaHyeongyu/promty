# Promty memory generation
#
# Copy the values you need into .env.local or backend/.env.local.
# Do not commit real API keys.

# Required to enable OpenAI-backed Memory Draft and Project Memory generation.
PROMTY_OPENAI_API_KEY=

# Optional. Defaults are shown here.
PROMTY_OPENAI_MODEL=gpt-5-mini
# Used only for the pre-generation cost estimate. Update when provider pricing changes.
PROMTY_OPENAI_INPUT_USD_PER_MILLION_TOKENS=0.25
PROMTY_OPENAI_OUTPUT_USD_PER_MILLION_TOKENS=2.00
PROMTY_OPENAI_TIMEOUT_SECONDS=90
PROMTY_OPENAI_REASONING_EFFORT=minimal
PROMTY_MEMORY_GENERATOR=openai
PROMTY_MEMORY_DRAFT_GENERATOR=openai
PROMTY_PROJECT_MEMORY_GENERATOR=openai

# Optional Gemini fallback.
PROMTY_GEMINI_API_KEY=
PROMTY_GEMINI_MODEL=gemini-2.5-flash
PROMTY_GEMINI_INPUT_USD_PER_MILLION_TOKENS=0.30
PROMTY_GEMINI_OUTPUT_USD_PER_MILLION_TOKENS=2.50
PROMTY_GEMINI_TIMEOUT_SECONDS=30

# Set both stage-specific generators to local to disable external memory generation.
# PROMTY_MEMORY_GENERATOR=local
# PROMTY_MEMORY_DRAFT_GENERATOR=local
# PROMTY_PROJECT_MEMORY_GENERATOR=local

# Production app/runtime.
DATABASE_URL=postgresql+psycopg://promty:promty@localhost:5432/promty
PROMTY_DATABASE_POOL_SIZE=5
PROMTY_DATABASE_MAX_OVERFLOW=2
PROMTY_DATABASE_POOL_TIMEOUT_SECONDS=5
PROMTY_DATABASE_POOL_RECYCLE_SECONDS=300
PROMTY_DATABASE_STATEMENT_TIMEOUT_MS=0
PROMTY_DATABASE_LOCK_TIMEOUT_MS=0
PROMTY_API_PUBLIC_URL=http://127.0.0.1:8011
PROMTY_APP_URL=http://127.0.0.1:5173
PROMTY_CORS_ORIGINS=http://127.0.0.1:5173,http://localhost:5173
# Keep false in production. Set true only for isolated local ingest testing.
PROMTY_ALLOW_ANONYMOUS_INGEST=false
PROMTY_EVENT_BATCH_MAX_BODY_BYTES=8388608
PROMTY_MEMORY_SLICE_EVENT_MAX_ROWS=500
PROMTY_MEMORY_SLICE_MAX_SLICES_PER_CALL=4
PROMTY_MEMORY_DRAFT_PROMPT_MAX_BYTES=131072
PROMTY_MEMORY_DRAFT_EVIDENCE_MAX_BYTES=98304
PROMTY_PROJECT_MEMORY_PROMPT_MAX_BYTES=262144
PROMTY_MEMORY_PROVIDER_RESPONSE_MAX_BYTES=1048576
PROMTY_MEMORY_PROVIDER_OUTPUT_MAX_TOKENS=8192
PROMTY_MEMORY_PROVIDER_WALL_DEADLINE_SECONDS=120
PROMTY_PROJECT_MEMORY_BATCH_MAX_DRAFTS=60
PROMTY_MEMORY_WORKER_POLL_SECONDS=2
PROMTY_MEMORY_WORKER_MAX_POLL_SECONDS=10
PROMTY_MEMORY_WORKER_HEARTBEAT_SECONDS=60
PROMTY_MEMORY_WORKER_CHUNK_CONCURRENCY=2
PROMTY_SESSION_COOKIE_SECURE=false
PROMTY_SESSION_COOKIE_SAMESITE=lax
PROMTY_ACCESS_TOKEN_TTL_SECONDS=3600

# Administrator access. Use immutable numeric GitHub IDs only.
PROMTY_ADMIN_GITHUB_IDS=
# Per-client sliding-window limits for public OAuth and administrator endpoints.
PROMTY_AUTH_RATE_LIMIT_REQUESTS=30
PROMTY_AUTH_RATE_LIMIT_WINDOW_SECONDS=60
PROMTY_ADMIN_RATE_LIMIT_REQUESTS=120
PROMTY_ADMIN_RATE_LIMIT_WINDOW_SECONDS=60
PROMTY_INGEST_RATE_LIMIT_REQUESTS=120
PROMTY_INGEST_RATE_LIMIT_WINDOW_SECONDS=60
# Forwarded client headers are trusted only from these reverse-proxy networks.
PROMTY_TRUSTED_PROXY_CIDRS=127.0.0.0/8,::1/128,172.16.0.0/12
PROMTY_ADMIN_AUDIT_RETENTION_DAYS=180

# GitHub OAuth and repository browser.
PROMTY_GITHUB_CLIENT_ID=
PROMTY_GITHUB_CLIENT_SECRET=
PROMTY_GITHUB_TOKEN_ENCRYPTION_KEY=
# Decrypt-only keys retained during GitHub token key rotation.
PROMTY_GITHUB_TOKEN_ENCRYPTION_PREVIOUS_KEYS=
PROMTY_OAUTH_STATE_SECRET=
PROMTY_JWT_SECRET=

# Application-level encryption for prompts, responses, and diff patches.
PROMTY_APP_ENCRYPTION_KEY=
# Comma-separated, decrypt-only keys retained during key rotation.
PROMTY_APP_ENCRYPTION_PREVIOUS_KEYS=
PROMTY_APP_ENCRYPTION_KEY_ID=local

# Memory worker process heartbeat used by container health checks.
PROMTY_MEMORY_WORKER_HEALTH_FILE=/tmp/promty-memory-worker.heartbeat
PROMTY_MEMORY_WORKER_HEALTH_TIMEOUT_SECONDS=180

# Community routes can be disabled as an operational rollback switch.
PROMTY_PUBLISHED_FLOWS_ENABLED=true
# Published flow asset storage. Use local for development and s3 for AWS.
PROMTY_PUBLISHED_FLOW_ASSET_STORAGE=local
PROMTY_PUBLISHED_FLOW_ASSET_ROOT=~/.promty/published-flow-assets
PROMTY_PUBLISHED_FLOW_ASSET_MAX_BYTES=5242880
PROMTY_PUBLISHED_FLOW_ASSET_MAX_COUNT_PER_FLOW=20
PROMTY_PUBLISHED_FLOW_ASSET_MAX_TOTAL_BYTES_PER_USER=104857600
PROMTY_COMMUNITY_RATE_LIMIT_REQUESTS=120
PROMTY_COMMUNITY_RATE_LIMIT_WINDOW_SECONDS=60
PROMTY_AWS_REGION=
PROMTY_AWS_S3_BUCKET=
PROMTY_AWS_S3_PREFIX=published-flow-assets

# FAQ/support inquiry notifications. Inquiries are still stored when email is disabled.
PROMTY_SUPPORT_EMAIL_PROVIDER=ses
PROMTY_SUPPORT_NOTIFICATION_EMAILS=
PROMTY_SUPPORT_FROM_EMAIL=support@promty.org
PROMTY_SUPPORT_RATE_LIMIT_REQUESTS=5
PROMTY_SUPPORT_RATE_LIMIT_WINDOW_SECONDS=300

# Bilingual SNS/community content studio. All publisher integrations are optional.
PROMTY_BUFFER_API_KEY=
# Base keys apply to both languages; <channel>.ko / <channel>.en override them.
PROMTY_BUFFER_CHANNEL_IDS={}
PROMTY_DEVTO_API_KEY=
PROMTY_DEVTO_ORGANIZATION_ID=
PROMTY_GITHUB_MARKETING_TOKEN=
PROMTY_GITHUB_MARKETING_REPOSITORY_ID=
PROMTY_GITHUB_MARKETING_DISCUSSION_CATEGORY_ID=
