# Promty memory generation
#
# Copy the values you need into .env.local or backend/.env.local.
# Do not commit real API keys.

# Required to enable OpenAI-backed Memory Draft and Project Memory generation.
PROMTY_OPENAI_API_KEY=

# Optional. Defaults are shown here.
PROMTY_OPENAI_MODEL=gpt-5-mini
PROMTY_OPENAI_TIMEOUT_SECONDS=90
PROMTY_OPENAI_REASONING_EFFORT=minimal
PROMTY_MEMORY_GENERATOR=openai
PROMTY_MEMORY_DRAFT_GENERATOR=openai
PROMTY_PROJECT_MEMORY_GENERATOR=openai

# Optional Gemini fallback.
PROMTY_GEMINI_API_KEY=
PROMTY_GEMINI_MODEL=gemini-2.5-flash
PROMTY_GEMINI_TIMEOUT_SECONDS=30

# Set both stage-specific generators to local to disable external memory generation.
# PROMTY_MEMORY_GENERATOR=local
# PROMTY_MEMORY_DRAFT_GENERATOR=local
# PROMTY_PROJECT_MEMORY_GENERATOR=local

# Production app/runtime.
DATABASE_URL=postgresql+psycopg://prompthub:prompthub@localhost:5432/prompthub
PROMPTHUB_API_PUBLIC_URL=http://127.0.0.1:8011
PROMPTHUB_APP_URL=http://127.0.0.1:5173
PROMPTHUB_CORS_ORIGINS=http://127.0.0.1:5173,http://localhost:5173
# Keep false in production. Set true only for isolated local ingest testing.
PROMPTHUB_ALLOW_ANONYMOUS_INGEST=false
PROMPTHUB_SESSION_COOKIE_SECURE=false
PROMPTHUB_SESSION_COOKIE_SAMESITE=lax

# GitHub OAuth and repository browser.
PROMPTHUB_GITHUB_CLIENT_ID=
PROMPTHUB_GITHUB_CLIENT_SECRET=
PROMPTHUB_GITHUB_TOKEN_ENCRYPTION_KEY=
PROMPTHUB_OAUTH_STATE_SECRET=
PROMPTHUB_JWT_SECRET=

# Application-level encryption for prompts, responses, and diff patches.
PROMPTHUB_APP_ENCRYPTION_KEY=
# Comma-separated, decrypt-only keys retained during key rotation.
PROMPTHUB_APP_ENCRYPTION_PREVIOUS_KEYS=
PROMPTHUB_APP_ENCRYPTION_KEY_ID=local

# Published flow asset storage. Use local for development and s3 for AWS.
PROMPTHUB_PUBLISHED_FLOW_ASSET_STORAGE=local
PROMPTHUB_PUBLISHED_FLOW_ASSET_ROOT=~/.prompthub/published-flow-assets
PROMPTHUB_PUBLISHED_FLOW_ASSET_MAX_BYTES=5242880
PROMPTHUB_AWS_REGION=
PROMPTHUB_AWS_S3_BUCKET=
PROMPTHUB_AWS_S3_PREFIX=published-flow-assets
