{
  "ServiceName": "promty-prod-api",
  "SourceConfiguration": {
    "AuthenticationConfiguration": {
      "AccessRoleArn": "arn:aws:iam::435917083683:role/promty-apprunner-ecr-access"
    },
    "AutoDeploymentsEnabled": false,
    "ImageRepository": {
      "ImageIdentifier": "435917083683.dkr.ecr.ap-southeast-2.amazonaws.com/promty/backend:latest",
      "ImageRepositoryType": "ECR",
      "ImageConfiguration": {
        "Port": "8011",
        "RuntimeEnvironmentVariables": {
          "PROMTY_API_PUBLIC_URL": "https://api.promty.org",
          "PROMTY_APP_URL": "https://promty.org",
          "PROMTY_CORS_ORIGINS": "https://promty.org,https://www.promty.org",
          "PROMTY_SESSION_COOKIE_SECURE": "true",
          "PROMTY_SESSION_COOKIE_SAMESITE": "lax",
          "PROMTY_PUBLISHED_FLOW_ASSET_STORAGE": "s3",
          "PROMTY_AWS_REGION": "ap-southeast-2",
          "PROMTY_AWS_S3_BUCKET": "promty-prod-assets-435917083683",
          "PROMTY_AWS_S3_PREFIX": "published-flow-assets",
          "PROMTY_APP_ENCRYPTION_KEY_ID": "aws-prod",
          "PROMTY_MEMORY_GENERATOR": "local",
          "PROMTY_MEMORY_DRAFT_GENERATOR": "local",
          "PROMTY_PROJECT_MEMORY_GENERATOR": "local"
        },
        "RuntimeEnvironmentSecrets": {
          "DATABASE_URL": "arn:aws:secretsmanager:ap-southeast-2:435917083683:secret:promty/prod/database-url-wYIxEV",
          "PROMTY_APP_ENCRYPTION_KEY": "arn:aws:secretsmanager:ap-southeast-2:435917083683:secret:promty/prod/app-encryption-key-puJg9H",
          "PROMTY_GITHUB_CLIENT_ID": "arn:aws:secretsmanager:ap-southeast-2:435917083683:secret:promty/prod/github-client-id-EwwvMI",
          "PROMTY_GITHUB_CLIENT_SECRET": "arn:aws:secretsmanager:ap-southeast-2:435917083683:secret:promty/prod/github-client-secret-ytHkHo",
          "PROMTY_GITHUB_TOKEN_ENCRYPTION_KEY": "arn:aws:secretsmanager:ap-southeast-2:435917083683:secret:promty/prod/github-token-encryption-key-p24aoY",
          "PROMTY_OAUTH_STATE_SECRET": "arn:aws:secretsmanager:ap-southeast-2:435917083683:secret:promty/prod/oauth-state-secret-OQeAVr",
          "PROMTY_JWT_SECRET": "arn:aws:secretsmanager:ap-southeast-2:435917083683:secret:promty/prod/jwt-secret-owy3sL"
        }
      }
    }
  },
  "InstanceConfiguration": {
    "Cpu": "0.25 vCPU",
    "Memory": "0.5 GB",
    "InstanceRoleArn": "arn:aws:iam::435917083683:role/promty-apprunner-instance"
  },
  "HealthCheckConfiguration": {
    "Protocol": "HTTP",
    "Path": "/health",
    "Interval": 10,
    "Timeout": 5,
    "HealthyThreshold": 1,
    "UnhealthyThreshold": 5
  },
  "NetworkConfiguration": {
    "EgressConfiguration": {
      "EgressType": "VPC",
      "VpcConnectorArn": "arn:aws:apprunner:ap-southeast-2:435917083683:vpcconnector/promty-prod-vpc-connector-nat/1/280069a9ab9e46e4817f07222989b896"
    },
    "IngressConfiguration": {
      "IsPubliclyAccessible": true
    }
  }
}
