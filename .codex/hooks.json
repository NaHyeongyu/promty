{
  "hooks": {
    "Stop": [
      {
        "hooks": [
          {
            "command": "python3 collector/src/cli.py capture-changes --tool codex-cli",
            "statusMessage": "Capturing PromptHub file changes",
            "timeout": 10,
            "type": "command"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "command": "python3 collector/src/cli.py capture --tool codex-cli",
            "statusMessage": "Capturing PromptHub event",
            "timeout": 5,
            "type": "command"
          }
        ]
      }
    ]
  }
}
