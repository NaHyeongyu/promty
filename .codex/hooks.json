{
  "hooks": {
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"$(git rev-parse --show-toplevel)/collector/src/cli.py\" capture-raw --output \"$(git rev-parse --show-toplevel)/docs/real-codex-payload.json\"",
            "timeout": 5,
            "statusMessage": "Capturing raw Codex hook payload"
          }
        ]
      }
    ]
  }
}
