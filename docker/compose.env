# Development-only defaults. Override these in the ignored root .env.local file.
PROMPTHUB_APP_ENCRYPTION_KEY=local-development-app-encryption-key
PROMPTHUB_GITHUB_TOKEN_ENCRYPTION_KEY=local-development-github-token-key
PROMPTHUB_JWT_SECRET=local-development-jwt-secret
PROMPTHUB_OAUTH_STATE_SECRET=local-development-oauth-state-secret
