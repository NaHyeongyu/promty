# Development-only defaults. Override these in the ignored root .env.local file.
PROMTY_APP_ENCRYPTION_KEY=local-development-app-encryption-key
PROMTY_GITHUB_TOKEN_ENCRYPTION_KEY=local-development-github-token-key
PROMTY_JWT_SECRET=local-development-jwt-secret
PROMTY_OAUTH_STATE_SECRET=local-development-oauth-state-secret
